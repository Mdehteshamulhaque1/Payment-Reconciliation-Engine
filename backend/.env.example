APP_NAME=Payment Reconciliation Engine API
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=false
ENVIRONMENT=development

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=payment_reconciliation_engine

# Optional override for fully qualified SQLAlchemy URL
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/payment_reconciliation_engine

# Security
SECRET_KEY=replace-me
JWT_ALGORITHM=HS256

# Celery & Redis (used by background tasks and caching)
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# Notes:
# - Keep secrets out of source control for production. Use a secret manager or CI/CD secrets.